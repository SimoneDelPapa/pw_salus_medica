.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# =========================
# FRONTEND (React / Vite)
# =========================
# Dipendenze Node.js (pesano tantissimo, vengono ricreate con npm install)
node_modules/

# Build di produzione (create automaticamente da Vite)
dist/
dist-ssr/

# Log di errore di npm/yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# BACKEND (Python / FastAPI)
# =========================
# File compilati da Python
__pycache__/
*.py[cod]
*$py.class

# Ambienti virtuali (dove si installano le librerie come fastapi, sqlalchemy)
env/
venv/
.env/
.venv/

# Database SQLite 
# IMPORTANTE: Impedisce di caricare il database con i dati dei pazienti online!
*.db
*.sqlite
*.sqlite3

